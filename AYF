-- وظيفة سرقة الأوامر وتحويلها لكود
local function logScript(code)
    ScriptBox.Text = code
end

-- مراقبة الأوامر (Remotes) - هذا الجزء يسرق "فعل" السكربتات الأخرى
local gmt = getrawmetatable(game)
setreadonly(gmt, false)
local old = gmt.__namecall

gmt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if method == "FireServer" then
        local code = "-- كود مسروق (AMT):\n" .. "game." .. self:GetFullName() .. ":FireServer("
        for i, v in pairs(args) do
            code = code .. tostring(v) .. (i < #args and ", " or "")
        end
        code = code .. ")"
        logScript(code)
    end
    return old(self, ...)
end)

-- زر النسخ للحافظة
CopyBtn.MouseButton1Click:Connect(function()
    setclipboard(ScriptBox.Text)
    CopyBtn.Text = "تم النسخ!"
    wait(1)
    CopyBtn.Text = "نسخ الكود"
end)

